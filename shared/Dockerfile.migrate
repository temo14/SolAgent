# One-shot Prisma migration runner — exits 0 on success, never restarts
# (docker-compose: restart: 'no', other services depend_on: service_completed_successfully)
FROM node:22-alpine
WORKDIR /app

COPY package.json ./
COPY shared/package.json ./shared/
COPY shared/prisma ./shared/prisma

RUN apk add --no-cache openssl libc6-compat
# --workspace=shared installs only shared + its deps (no other services)
RUN npm install --legacy-peer-deps --workspace=shared

COPY shared ./shared
WORKDIR /app/shared

# Generate client so Prisma CLI can resolve the schema correctly
RUN npx prisma generate --schema=prisma/schema.prisma

# migrate deploy applies pending migrations without generating the client again
CMD ["npx", "prisma", "migrate", "deploy", "--schema=prisma/schema.prisma"]
