    "db:studio": "prisma studio --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "~5.8.2"
  }
}
