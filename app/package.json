{
  "name": "solagent-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:mainnet": "vite --port 3000 --mode mainnet",
    "dev:localnet": "vite --port 3000 --mode localnet",
    "build": "tsc && vite build",
