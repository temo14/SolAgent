# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: use localhost; Docker Compose: use "postgres" as hostname
DATABASE_URL=postgresql://archon:devpassword@localhost:5432/archon_devnet

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Tether QVAC (mandatory rule parser — OpenAI-compatible HTTP API, no cloud fallback) ─
# Docker Compose: service `qvac` — rule-engine uses http://qvac:11434 (set in compose).
# Host-only rule-engine: QVAC_BASE_URL=http://localhost:11434 and run: qvac serve openai
# Optional: if server started with --api-key, set QVAC_API_KEY (Bearer token).
QVAC_BASE_URL=http://qvac:11434
# Must match an alias in docker/qvac/qvac.config.json serve.models
QVAC_MODEL=archon-parser
# QVAC_API_KEY=

# ── Solana (devnet) ────────────────────────────────────────────────────────────
# Primary RPC — used by execution-engine and condition-evaluator (same URL as in docs).
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=REPLACE_ME
SOLANA_RPC_FALLBACK=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# ── Helius ────────────────────────────────────────────────────────────────────
HELIUS_API_KEY=REPLACE_ME
# HMAC secret used to verify incoming webhook signatures
HELIUS_WEBHOOK_SECRET=REPLACE_ME_32_CHAR_MINIMUM
# Public URL of your event-listener reachable by Helius (ngrok or cloud)
HELIUS_WEBHOOK_URL=https://REPLACE_ME.ngrok.io/webhooks/helius

# ── Jupiter ───────────────────────────────────────────────────────────────────
JUPITER_BASE_URL=https://quote-api.jup.ag/v6

# ── Pyth Benchmarks (simulation only — no key needed) ────────────────────────
PYTH_HERMES_URL=https://hermes.pyth.network

# ── Auth (SIWS + JWT) ─────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_32_CHAR_MINIMUM_SECRET
JWT_EXPIRY=86400

# Dev-only SIWS bypass (see app VITE_DEV_WALLET). Never enable on a public deployment.
# api-gateway runs with NODE_ENV=production under docker-compose — set AUTH_DEV_BYPASS=true
# and the same base58 pubkey as the app for POST /auth/dev-bypass to work.
# AUTH_DEV_BYPASS=true
# AUTH_DEV_BYPASS_WALLET=REPLACE_WITH_SAME_PUBKEY_AS_VITE_DEV_WALLET

# ── Agent Key Master (per-user isolated signing keypairs) ─────────────────────
# 32-byte master secret. Each user's agent keypair is derived as:
#   seed = HMAC-SHA256(key=AGENT_KEY_MASTER, data="solagent:agent:v1:<ownerPubkey>")
#   agentKeypair = Ed25519.fromSeed(seed)
# No individual keypairs are stored — only this secret needs protecting.
# Generate with: openssl rand -hex 32
AGENT_KEY_MASTER=REPLACE_ME_32_CHAR_MINIMUM_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
# React dev server URL (Vite default port 3000)
CORS_ORIGIN=http://localhost:3000

# ── Service Ports ────────────────────────────────────────────────────────────
# Vite stays on 3000; services start at 4000 to avoid collision
API_GATEWAY_PORT=4000
RULE_ENGINE_PORT=4001
EVENT_LISTENER_PORT=4002
CONDITION_EVALUATOR_PORT=4003
EXECUTION_ENGINE_PORT=4004
AUDIT_INDEXER_PORT=4005

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
